{
  "info": {
    "name": "Sicredi Bolecode API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Bolecode - BOL (Híbrido: linha digitável + código de barras + QR PIX)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/bolecode",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nf\":        \"000123\",\n  \"filial\":    \"010101\",\n  \"prefixo\":   \"NF\",\n  \"parcela\":   \"001\",\n  \"frmpag\":    \"BOL\",\n  \"valor\":     1500.00,\n  \"vencto\":    \"2026-04-30\",\n  \"nome\":      \"Hugo Cini SA\",\n  \"documento\": \"76490572000168\",\n  \"tpdoc\":     \"cnpj\",\n  \"cep\":       \"91250000\",\n  \"cidade\":    \"Porto Alegre\",\n  \"uf\":        \"RS\",\n  \"endereco\":  \"Av Ipiranga 1000\",\n  \"bairro\":    \"Azenha\",\n  \"fantasia\":  \"Hugo Cini\"\n}"
        }
      }
    },
    {
      "name": "Bolecode - R$ (PIX simples: apenas QR PIX)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/bolecode",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
