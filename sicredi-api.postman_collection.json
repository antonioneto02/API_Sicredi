          "raw": "{\n  \"nf\":        \"000456\",\n  \"filial\":    \"010101\",\n  \"prefixo\":   \"NF\",\n  \"parcela\":   \"001\",\n  \"frmpag\":    \"R$\",\n  \"valor\":     350.50,\n  \"vencto\":    \"2026-04-30\",\n  \"nome\":      \"Nerias Lima Sousa\",\n  \"documento\": \"81490690387\",\n  \"tpdoc\":     \"cpf\",\n  \"cep\":       \"01310100\",\n  \"cidade\":    \"São Paulo\",\n  \"uf\":        \"SP\",\n  \"endereco\":  \"Av Paulista 1000\",\n  \"bairro\":    \"Bela Vista\",\n  \"fantasia\":  \"\"\n}"
